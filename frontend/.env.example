# .env.example
# No secrets are required for the browser app.
# All config (app version, build date, commit hash) is injected at build
# time by Vite's `define` option and is never read from environment
# variables at runtime.
#
# If you add optional VITE_* variables in the future, document them here
# with placeholder values and commit this file. Never commit real secrets.
#
# Required for build metadata (injected by Vite):
# Example environment variables for Vite browser app
# Only VITE_ variables are exposed to the browser
VITE_ENV=development
VITE_API_URL=https://api.example.com
VITE_FEATURE_FLAG_EXAMPLE=false
# Example (uncomment if you add API base URL overrides):
# VITE_API_BASE_URL=/api
# VITE_ENABLE_MSW=false
