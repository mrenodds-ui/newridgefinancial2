{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NR2 Trend Chart Insight",
  "type": "object",
  "required": ["widget_type", "title", "data", "source_refs", "confidence"],
  "additionalProperties": false,
  "properties": {
    "widget_type": { "const": "trend-chart" },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "data": {
      "type": "object",
      "required": ["series"],
      "additionalProperties": false,
      "properties": {
        "series": {
          "type": "array",
          "minItems": 1,
          "maxItems": 24,
          "items": {
            "type": "object",
            "required": ["label"],
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string", "maxLength": 40 },
              "value": { "type": ["number", "null"] }
            }
          }
        },
        "unit": { "type": "string", "enum": ["dollars", "percent", "count", "days"] },
        "annotations": {
          "type": "array",
          "maxItems": 6,
          "items": { "type": "string", "maxLength": 120 }
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string",
        "pattern": "^(softdent|qb|nr2|import):[a-z0-9_./-]+:[0-9]{4}-[0-9]{2}(-[0-9]{2})?$"
      }
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "explanation": { "type": "string", "maxLength": 280 }
  }
}
