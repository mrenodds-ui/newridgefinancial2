{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NR2 Alert Banner Insight",
  "type": "object",
  "required": ["widget_type", "title", "data", "source_refs", "confidence"],
  "additionalProperties": false,
  "properties": {
    "widget_type": { "const": "alert-banner" },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "data": {
      "type": "object",
      "required": ["severity", "message"],
      "additionalProperties": false,
      "properties": {
        "severity": { "type": "string", "enum": ["info", "warn", "critical"] },
        "message": { "type": "string", "minLength": 1, "maxLength": 400 },
        "value": { "type": ["number", "null"] },
        "unit": { "type": "string", "enum": ["dollars", "percent", "count", "days", "text"] }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string",
        "pattern": "^(softdent|qb|nr2|import):[a-z0-9_./-]+:[0-9]{4}-[0-9]{2}(-[0-9]{2})?$"
      }
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "explanation": { "type": "string", "maxLength": 280 },
    "action_cta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "maxLength": 60 },
        "route": { "type": "string", "enum": ["financial", "claims", "ar", "softdent", "quickbooks", "hal", "office-manager", "taxes"] }
      }
    }
  }
}
