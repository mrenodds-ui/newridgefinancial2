      "requiredFields": ["production"],
      "optionalFields": ["collections", "insurance", "patient", "provider", "period"],
      "fieldAliases": {
        "production": ["production", "Production", "grossProduction", "netProduction"],
        "collections": ["collections", "Collections"],
        "insurance": ["insurance", "Insurance"],
        "patient": ["patient", "Patient"],
