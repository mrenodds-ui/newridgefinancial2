{
  "version": 1,
  "cacheDirs": {
    "softdent": "app_data/nr2/document_inbox/softdent",
    "quickbooks": "app_data/nr2/document_inbox/quickbooks"
  },
  "upstreamRoots": {
    "softdent": {
      "envVars": ["NR2_SOFTDENT_EXPORT_SOURCE", "SOFTDENT_SOURCE_DIR"],
      "defaultPaths": [
        "C:\\ProgramData\\Sensei Gateway Client\\DataSync",
        "C:\\Users\\mreno\\SoftDentBridge\\exports",
        "C:\\SoftDentFinancialExports",
        "C:\\NewRidgeBridge\\exports"
      ],
      "cacheDir": "app_data/nr2/document_inbox/softdent",
      "collectorHints": {
        "bridge_aggregate": "New Ridge Bridge Aggregate Generator + NR2 HAL Import Sync",
        "account_aging_jsonl": "SoftDent financial pipeline (account_aging.jsonl)",
        "daysheet_jsonl": "SoftDent daysheet export pipeline"
      }
    },
    "quickbooks": {
      "envVars": ["NR2_QUICKBOOKS_EXPORT_SOURCE", "QUICKBOOKS_SOURCE_DIR"],
      "defaultPaths": [
        "C:\\Users\\mreno\\QuickBooksExports",
        "C:\\SoftDentFinancialExports"
