      "cacheDir": "app_data/nr2/document_inbox/quickbooks",
      "collectorHints": {
        "qb_sdk_summary": "QuickBooks SDK refresh scheduled task",
        "qb_sdk_expense_categories": "QuickBooks SDK expense category probe"
