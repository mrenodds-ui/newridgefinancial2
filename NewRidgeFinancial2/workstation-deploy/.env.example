# NR2 Office Workstation — per-PC settings (Setup-Workstation.ps1 writes .env on install)

# This computer's station name (must match SideNotes / office routing)
# NR2_WORKSTATION_STATION=Room 2
# NR2_SIDENOTES_MY_STATION=Room 2

# HAL hub PC — Start Program on port 8765 (use LAN IP, not 127.0.0.1 on remote desks)
# NR2_HAL_HUB_URL=http://192.168.1.50:8765

# Fast Ask HAL on chat8b only (default on workstations)
# NR2_WORKSTATION_FAST_HAL=1

# Start hidden — popups still show; double-click desktop icon to open messenger
# NR2_WORKSTATION_START_HIDDEN=1

# NR2_SIDENOTES_HUB_DATA=C:\softdent\HAL-SideNotes-Workstation\data
