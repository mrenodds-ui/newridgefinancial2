# NewRidgeFinancial 2.0 desktop — active configuration only.
# Copy to repo root .env or set as system/user environment variables.
# The NR2 launcher (scripts/start_nr2_desktop.ps1) loads repo-root .env when present.

# Loopback HTTP port for the pywebview desktop shell (default 8765)
NR2_HTTP_PORT=8765

# Import cache — document page folders (HAL reads only from here)
SOFTDENT_IMPORT_DIR=app_data/nr2/document_inbox/softdent
QUICKBOOKS_IMPORT_DIR=app_data/nr2/document_inbox/quickbooks

# Auto-pull upstream exports into document-inbox folders.
# With pipeline-first + direct-first (defaults), scheduled copy is optional — set 0 to skip.
NR2_AUTO_PULL_EXPORTS=0

# Widget import mode: read newest upstream SoftDent/QuickBooks exports directly (default on).
# When direct-first is on, upstream direct reads win over a fresher document-inbox cache copy.
# Cache folders remain as fallback; set 0 to use cache-only + scheduled Sync-HAL-Imports.
NR2_DIRECT_FIRST_IMPORTS=1
# Prefer live bridge JSON, account_aging.jsonl, analytics DB, and QB probe over stale inbox copies.
# Pipeline-first only affects tie-breaking among live pipeline sources when direct rows are absent.
NR2_PIPELINE_FIRST_IMPORTS=1
# Optional: mirror direct reads into document-inbox on manual refresh (default off).
NR2_DIRECT_FIRST_WRITE_CACHE=0

# Legacy SoftDent refresh automation (C:\New folder\.env): set NR2_PRIMARY=1 so the
# 45-minute pipeline passes on NR2 import readiness instead of legacy dashboard :8787.
# Install: powershell -File NewRidgeFinancial2/import-automation/Install-SoftDent-Refresh-NR2-Mode.ps1

# Upstream export roots (pipeline-first reads these directly; auto-pull copies into document-inbox)
# Readiness script (Verify-HAL-Readiness.ps1) fails Phase 0 until at least one path per system exists.
NR2_SOFTDENT_EXPORT_SOURCE=C:\SoftDentFinancialExports
NR2_QUICKBOOKS_EXPORT_SOURCE=C:\SoftDentFinancialExports
SOFTDENT_SOURCE_DIR=C:\ProgramData\Sensei Gateway Client\DataSync
QUICKBOOKS_SOURCE_DIR=

# SideNotes hub (desktop reads shared workstation inbox)
NR2_SIDENOTES_HUB_DATA=C:\softdent\HAL-SideNotes-Workstation\data

# NR2 Office Workstation (StartWorkstation.bat, port 8766)
# NR2_PRACTICE_NAME=New Ridge Family Dental
# NR2_WORKSTATION_ON_TOP=1
# NR2_HAL_HUB_URL=http://192.168.1.50:8765
# NR2_WORKSTATION_FAST_HAL=1   # Ask HAL uses chat8b only (default on workstation)
# NR2_WORKSTATION_FAST_HAL=0   # Use full HAL routing like Start Program

# HAL office message hub — Start Program PC (owner/admin machine with office speakers)
# Hub PC: leave NR2_HAL_HUB_URL unset to auto-advertise this PC's LAN IP on port 8765.
# Each operatory/front-desk PC running StartWorkstation.bat must set NR2_HAL_HUB_URL to the hub PC:
# NR2_HAL_HUB_URL=http://192.168.1.50:8765
# Optional shared folder for office-channel + station registry (all PCs same path):
# NR2_OFFICE_HUB_DATA=\\HUB-PC\NR2Office
# NR2_HAL_HUB_DUCK_MUSIC=1
# NR2_HAL_HUB_DUCK_PROCESSES=Pandora.exe,chrome.exe
# NR2_HAL_HUB_VOICE_STYLE=hal9000

# HAL office hub — shared inbound queue + office channel (Start Program / port 8765)
# Workstations POST to NR2_HAL_HUB_URL; hub writes hal-hub-inbound.json + office-channel.json here.
NR2_HAL_HUB_URL=http://127.0.0.1:8765
NR2_OFFICE_HUB_DATA=app_data/nr2/office
# NR2_HAL_HUB_DUCK_MUSIC=1
# NR2_HAL_HUB_DUCK_PROCESSES=Pandora.exe
# NR2_HAL_HUB_VOICE_STYLE=hal9000

# HAL Documents queue — financial aggregates only (default). Set 0 to include OCR invoices.
NR2_HAL_FINANCIAL_NUMBERS_ONLY=1

# Automated accounting document OCR (relative to repo root unless absolute)
NR2_DOCUMENT_INBOX=app_data/nr2/document_inbox
NR2_DOCUMENT_INBOX_ARCHIVE=app_data/nr2/document_inbox/processed
LOCAL_AI_ACCOUNTING_DB_PATH=app_data/nr2/accounting_documents.sqlite3

# QuickBooks period export — current + prior month only (replaced each sync, not accumulated)
NR2_FINANCIAL_ANALYTICS_DB=C:\SoftDentFinancialExports\softdent_financial_analytics.db
NR2_QB_MONTHLY_SDK=auto
NR2_QB_MONTHLY_SDK_MONTHS=2

# Import cache retention — purge SoftDent/QuickBooks import files after this many days
NR2_IMPORT_RETENTION_DAYS=7

# HAL authorized direct read from SoftDent/QuickBooks (staff approval)
NR2_HAL_PRACTICE_PULL_APPROVED=1

# Documents page — scheduled SoftDent/QuickBooks pull (every 30 minutes)
# Register: NewRidgeFinancial2/import-automation/Register-HAL-Document-Source-Automation.ps1
# Manual run: NewRidgeFinancial2/import-automation/Sync-HAL-Document-Sources.ps1
# Pre-flight: NewRidgeFinancial2/import-automation/Verify-HAL-Readiness.ps1 [-Pull] [-PullFull]
# Full 100% pull: NewRidgeFinancial2/import-automation/Pull-HAL-Full-Practice-Sources.ps1 [-VerifyHal]
# Sets NR2_HAL_FULL_PULL=1 (all softdent_* / quickbooks_* exports + claims verification + 100 narrative templates)

# Production must-fix (Moonshot) — defaults enforced by browser_app.py
# NR2_ENFORCE_TLS=1
# NR2_DB_ENCRYPTION=1
# NR2_BIND_HOST=127.0.0.1
# NR2_IMPORT_POSTING_MAX_HOURS=24
# NR2_IMPORT_DAILY_OPS_HOURS=24
# pip install sqlcipher3 keyring
# Optional dev only: NR2_ALLOW_HTTP=1 NR2_DB_ENCRYPTION=0

# SoftDent ODBC read-only lane (patient/appointment/claim depth beyond financial exports)
# Run discovery: python NewRidgeFinancial2/scripts/discover_softdent_odbc_schema.py
# SOFTDENT_ODBC_DSN=SoftDentReadOnly
# NR2_SOFTDENT_ODBC_DSN=SoftDentReadOnly
# SOFTDENT_ODBC_USER=nr2_reader
# SOFTDENT_ODBC_PASSWORD=
# SoftDent GUI Sign On (Change Login / Sign On dialog) — local .env only, never commit:
# SOFTDENT_SIGNON_USER=Dr
# SOFTDENT_SIGNON_PASSWORD=
# Optional Collections menu keys after Reports→Accounting (default c):
# SOFTDENT_COLLECTIONS_MENU_KEYS=c
# SOFTDENT_ODBC_TIMEOUT=30
# NR2_SOFTDENT_ODBC_MAX_AGE_MINUTES=60
# NR2_CONSENT_EXECUTOR=1
# Table queries — customize column names after discovery:
# Prefer: python scripts/discover_softdent_odbc_schema.py --out app_data/nr2/softdent_schema_discovery.json
# When env SQL is empty, extract uses discovery suggestedEnv (default on):
# NR2_SOFTDENT_USE_DISCOVERY_QUERIES=1
# SOFTDENT_ODBC_PATIENTS_QUERY=SELECT PatientID AS patient_id, LastName+', '+FirstName AS patient_name, FirstVisitDate AS first_visit_date, LastVisitDate AS last_visit_date FROM Patient WHERE Active=1
# SOFTDENT_ODBC_PROCEDURES_QUERY=SELECT PatientID AS patient_id, ProcDate AS proc_date, ADACode AS ada_code, Tooth AS tooth, Surface AS surface, ProviderID AS provider_code, Description AS description, Production AS production FROM Procedures WHERE ProcDate >= DATEADD(month, -24, GETDATE())
# SOFTDENT_ODBC_PAYMENTS_QUERY=SELECT PatientID AS patient_id, PaymentDate AS payment_date, Amount AS amount, Payer AS payer, Method AS method FROM Payments WHERE PaymentDate >= DATEADD(month, -24, GETDATE())
# Highest value for named carriers / claim readiness:
# SOFTDENT_ODBC_CLAIMS_QUERY=SELECT ClaimID AS claim_id, PatientName AS patient_name, Payer AS payer, ServiceDate AS service_date, ClaimAmount AS claim_amount, ClaimStatus AS claim_status FROM Claims WHERE ServiceDate >= DATEADD(month, -24, GETDATE())
# SOFTDENT_ODBC_APPOINTMENTS_QUERY=SELECT PatientID AS patient_id, ApptDate AS appt_date, ProviderCode AS provider_code, Status AS status FROM Appointments WHERE ApptDate >= CAST(GETDATE() AS DATE)
# SOFTDENT_ODBC_PROVIDERS_QUERY=SELECT ProviderCode AS provider_code, ProviderName AS provider_name FROM Providers
# SOFTDENT_ODBC_ADJUSTMENTS_QUERY=SELECT PatientID AS patient_id, AdjDate AS adj_date, ADACode AS ada_code, Amount AS amount, Description AS description FROM Adjustments WHERE AdjDate >= DATEADD(month, -24, GETDATE())
# Patient insurance → sd_patient_insurance (dossier Availity auto-eligibility). Override SQL after discovery:
# SOFTDENT_ODBC_INSURANCE_QUERY=
# Optional CSV fallback (Patient Insurance export):
# SOFTDENT_INSURANCE_CSV_PATH=C:\SoftDentFinancialExports\patient_insurance_YYYYMMDD.csv

# Legacy backend keys below are NOT used by NR2 desktop:
# AI_FRONTEND_MODEL, QUICKBOOKS_DSN, SOFTDENT_AUTO_PULL_ENABLED, port 8095, etc.

# --- Clearinghouse eligibility (270/271) ---
# Local mock (no credentials): CLEARINGHOUSE_MOCK=1
# CLEARINGHOUSE_MOCK=1

# Availity Coverages (preferred when AVAILITY_KEY_CODE / AVAILITY_SECRET are set)
# Demo plan (canned responses, no PHI): AVAILITY_USE_DEMO=1 (default)
# AVAILITY_KEY_CODE=
# AVAILITY_SECRET=
# AVAILITY_CLIENT_ID=
# AVAILITY_CLIENT_SECRET=
# AVAILITY_USE_DEMO=1
# AVAILITY_SCOPE=healthcare-hipaa-transactions-demo
# AVAILITY_BASE_URL=https://api.availity.com
# AVAILITY_TOKEN_URL=https://api.availity.com/v1/token
# AVAILITY_COVERAGES_URL=https://api.availity.com/availity/v1/coverages
# AVAILITY_MOCK_SCENARIO=Coverages-Complete-i
# Standard/live plan: AVAILITY_USE_DEMO=0 and AVAILITY_SCOPE=healthcare-hipaa-transactions
# If live scope is not approved yet, keep AVAILITY_LIVE_FALLBACK_DEMO=1 (default) so HAL still gets demo coverages.
# AVAILITY_LIVE_FALLBACK_DEMO=1

# DentalXChange XConnect
# DENTALXCHANGE_API_KEY=
# DENTALXCHANGE_API_SECRET=
# DENTALXCHANGE_BASE_URL=https://api.dentalxchange.com
# DENTALXCHANGE_ELIGIBILITY_PATH=/xconnect/eligibility/v1
# DENTALXCHANGE_ELIGIBILITY_URL=https://api.dentalxchange.com/xconnect/eligibility/v1

# Change Healthcare / Optum Eligibility v3
# CHANGE_HEALTHCARE_CLIENT_ID=
# CHANGE_HEALTHCARE_CLIENT_SECRET=
# CHANGE_HEALTHCARE_USE_SANDBOX=1
# CHANGE_HEALTHCARE_SANDBOX_URL=https://sandbox-apigw.optum.com
# CHANGE_HEALTHCARE_BASE_URL=https://apigw.optum.com
# CHANGE_HEALTHCARE_ELIGIBILITY_URL=https://sandbox-apigw.optum.com/medicalnetwork/eligibility/v3/
# NR2_PROVIDER_NPI=          # Practice NPI for Availity 271 / dossier eligibility (required for live eligibility fetch)
# NR2_PROVIDER_ORG_NAME=New Ridge Family Dental

# Patient dossier Availity eligibility (hal-10497)
# DOSSIER_ELIGIBILITY_ENABLED=1   # Kill switch — set 0 to omit live eligibility resolution
# Requires NR2_PROVIDER_NPI for providerNPI when SoftDent lacks insurance fields use HAL fetch_eligibility_271 or dossier overrides.

# Vyne / Desktop Tesia (optional live API; staff UI remains Desktop Tesia)
# VYNE_API_KEY=
# TESIA_API_KEY=
# VYNE_API_SECRET=
# VYNE_BEARER_TOKEN=
# VYNE_BASE_URL=https://api.vynedental.com
# VYNE_ELIGIBILITY_PATH=/eligibility/v1
# VYNE_ELIGIBILITY_URL=
