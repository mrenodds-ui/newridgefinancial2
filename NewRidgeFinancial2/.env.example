# NewRidgeFinancial 2.0 desktop — active configuration only.
# Copy to repo root .env or set as system/user environment variables.
# The NR2 launcher (scripts/start_nr2_desktop.ps1) loads repo-root .env when present.

# Loopback HTTP port for the pywebview desktop shell (default 8765)
NR2_HTTP_PORT=8765

# Import cache — document page folders (HAL reads only from here)
SOFTDENT_IMPORT_DIR=app_data/nr2/document_inbox/softdent
QUICKBOOKS_IMPORT_DIR=app_data/nr2/document_inbox/quickbooks

# Auto-pull upstream exports into document-inbox folders.
# With pipeline-first + direct-first (defaults), scheduled copy is optional — set 0 to skip.
NR2_AUTO_PULL_EXPORTS=0

# Widget import mode: read newest upstream SoftDent/QuickBooks exports directly (default on).
# Cache folders remain as fallback; set 0 to use cache-only + scheduled Sync-HAL-Imports.
NR2_DIRECT_FIRST_IMPORTS=1
# Prefer live bridge JSON, account_aging.jsonl, analytics DB, and QB probe over stale inbox copies.
NR2_PIPELINE_FIRST_IMPORTS=1
# Optional: mirror direct reads into document-inbox on manual refresh (default off).
NR2_DIRECT_FIRST_WRITE_CACHE=0

# Upstream export roots (pipeline-first reads these directly; auto-pull copies into document-inbox)
# Readiness script (Verify-HAL-Readiness.ps1) fails Phase 0 until at least one path per system exists.
NR2_SOFTDENT_EXPORT_SOURCE=C:\SoftDentFinancialExports
NR2_QUICKBOOKS_EXPORT_SOURCE=C:\SoftDentFinancialExports
SOFTDENT_SOURCE_DIR=C:\ProgramData\Sensei Gateway Client\DataSync
QUICKBOOKS_SOURCE_DIR=

# SideNotes hub (desktop reads shared workstation inbox)
NR2_SIDENOTES_HUB_DATA=C:\softdent\HAL-SideNotes-Workstation\data

# HAL Documents queue — financial aggregates only (default). Set 0 to include OCR invoices.
NR2_HAL_FINANCIAL_NUMBERS_ONLY=1

# Automated accounting document OCR (relative to repo root unless absolute)
NR2_DOCUMENT_INBOX=app_data/nr2/document_inbox
NR2_DOCUMENT_INBOX_ARCHIVE=app_data/nr2/document_inbox/processed
LOCAL_AI_ACCOUNTING_DB_PATH=app_data/nr2/accounting_documents.sqlite3

# QuickBooks period export — current + prior month only (replaced each sync, not accumulated)
NR2_FINANCIAL_ANALYTICS_DB=C:\SoftDentFinancialExports\softdent_financial_analytics.db
NR2_QB_MONTHLY_SDK=auto
NR2_QB_MONTHLY_SDK_MONTHS=2

# Import cache retention — purge SoftDent/QuickBooks import files after this many days
NR2_IMPORT_RETENTION_DAYS=7

# HAL authorized direct read from SoftDent/QuickBooks (staff approval)
NR2_HAL_PRACTICE_PULL_APPROVED=1

# Documents page — scheduled SoftDent/QuickBooks pull (every 30 minutes)
# Register: NewRidgeFinancial2/import-automation/Register-HAL-Document-Source-Automation.ps1
# Manual run: NewRidgeFinancial2/import-automation/Sync-HAL-Document-Sources.ps1
# Pre-flight: NewRidgeFinancial2/import-automation/Verify-HAL-Readiness.ps1 [-Pull] [-PullFull]
# Full 100% pull: NewRidgeFinancial2/import-automation/Pull-HAL-Full-Practice-Sources.ps1 [-VerifyHal]
# Sets NR2_HAL_FULL_PULL=1 (all softdent_* / quickbooks_* exports + claims verification + 100 narrative templates)

# Legacy backend keys below are NOT used by NR2 desktop:
# AI_FRONTEND_MODEL, QUICKBOOKS_DSN, SOFTDENT_AUTO_PULL_ENABLED, port 8095, etc.
