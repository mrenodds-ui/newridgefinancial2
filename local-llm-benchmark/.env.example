# Ollama connection (defaults match this workstation's HAL GPU layout)
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL_FAST=hal-chat:8b
OLLAMA_MODEL_HEAVY=hal-escalate:30b
OLLAMA_MAX_TOKENS=512
# Qwen3 30B uses think=false by default (OLLAMA_HEAVY_THINK=1 to enable thinking mode)
OLLAMA_HEAVY_THINK=0
