# Add your OpenAI API key here
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
QUICKBOOKS_DSN=QuickBooks Data QRemote

# Backend auth users are loaded from deployment configuration.
# Prefer password_hash entries. Plaintext password is a compatibility fallback only.
# APP_AUTH_USERS_JSON must be generated for your environment.
# Do not use example hashes in production.
# Example shape only:
# APP_AUTH_USERS_JSON=[{"username":"admin","display_name":"Administrator","password_hash":"<pbkdf2-or-approved-hash>","roles":["dashboard:read","hal:operator","admin"]}]
APP_AUTH_USERS_JSON=
# Required for production/staging or when APP_ENV is unset. Use a long random value in deployment.
# APP_AUTH_SESSION_SECRET=

# HAL persistence paths
HAL_SQLITE_PATH=
HAL_CHROMA_PATH=
HAL_EMBEDDING_PROVIDER=onnx-minilm

# Optional approved read-only QuickBooks summary queries for HAL.
# HAL will not run arbitrary SQL. If these are blank, HAL will try built-in
# read-only fallback templates for common QODBC summary topics.
HAL_QB_REVENUE_SQL=SELECT TOP 1 TotalIncome, ReportPeriod FROM ProfitAndLossSummary ORDER BY ReportPeriod DESC
HAL_QB_EXPENSES_SQL=SELECT TOP 1 TotalExpense, ReportPeriod FROM ProfitAndLossSummary ORDER BY ReportPeriod DESC
HAL_QB_AR_SQL=SELECT TOP 1 BalanceRemaining AS OutstandingAR, TxnDate AS ReportDate, RefNumber FROM Invoice ORDER BY TxnDate DESC

# Local LLM runtime (AMD Radeon RX 9060 XT 16GB — Vulkan-first Ollama on Windows)
# Dual-lane setup: 14B frontend chat on :11434, 14B backend review on :11435.
# run_frontend_model.ps1 and run_backend_model.ps1 are long-running foreground processes; keep each terminal open.
# Profile defaults live in evals/local_model_profiles.json (Queen3 14B on both daily lanes).
# Model weights, GGUF outputs, caches, and runtime artifacts are LOCAL-ONLY.
# Store them under models/ or .local_models/ (gitignored) — never commit weights or quantized files.
AI_RUNTIME=ollama
AI_GPU_BACKEND=vulkan
AI_GPU_LAYERS=auto
AI_CONTEXT_SIZE=3072
AI_FRONTEND_CONTEXT_SIZE=3072
AI_BACKEND_CONTEXT_SIZE=3072
AI_FRONTEND_BASE_URL=http://127.0.0.1:11434
AI_BACKEND_BASE_URL=http://127.0.0.1:11435
AI_FRONTEND_MODEL=queen3:14b
AI_BACKEND_MODEL=queen3:14b
# Optional Ollama-specific model tag overrides (same precedence as AI_* when AI_* is unset)
# OLLAMA_FRONTEND_MODEL=queen3:14b
# OLLAMA_BACKEND_MODEL=queen3:14b
# Used by HAL, LiteLLM lane routing, and scripts/run_local_model_ab_eval.py profile resolution.
# Optional custom local aliases after quantize/create scripts (not the default app tags)
# AI_FRONTEND_MODEL=frontend-24b-q4
# AI_BACKEND_MODEL=backend-30b-q4
AI_FRONTEND_QUANT=Q4_K_M
AI_BACKEND_QUANT=Q4_K_S
# llama.cpp direct serving (optional; set AI_RUNTIME=llama_cpp and point paths at local GGUF files)
# AI_FRONTEND_MODEL_PATH=.local_models/frontend/frontend-24b.Q4_K_M.gguf
# AI_BACKEND_MODEL_PATH=.local_models/backend/backend-30b.Q4_K_S.gguf
# Leave OLLAMA_NUM_GPU_OVERRIDE unset for profile GPU offload (num_gpu=999 = all layers on frontend lane).
# Set OLLAMA_NUM_GPU_OVERRIDE=0 only when forcing CPU-only debugging.
# OLLAMA_NUM_GPU_OVERRIDE=
# Legacy single-Ollama URL (frontend lane fallback when AI_FRONTEND_BASE_URL is unset)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# LiteLLM proxy lane URLs (match AI_*_BASE_URL defaults; used by scripts/litellm_ollama_router.yaml)
# OLLAMA_FRONTEND_BASE_URL=http://127.0.0.1:11434
# OLLAMA_BACKEND_BASE_URL=http://127.0.0.1:11435
# Isolated 235B evaluator lane only — not used by normal LiteLLM aliases or HAL chat/coder routes
# OLLAMA_EVALUATOR_BASE_URL=http://127.0.0.1:11436
# Experimental fast structured reviewer lane (opt-in only; does not replace daily 14B chat/review)
# Intended for insurance narrative fact-checking, missing-data detection, citation compliance, JSON review.
# Do not run at the same time as the 235B evaluator (:11436). Benchmark against qwen3-coder:30b before adoption.
# AI_FAST_REVIEW_BASE_URL=http://127.0.0.1:11437
# Supported Ollama tag (default when unset): qwen3-coder:30b
# The documented GGUF name Qwen3-Coder-30B-A3B-Instruct is not in the Ollama registry; use your
# exact local tag here for Ollama, or serve the GGUF via llama.cpp with a custom import tag.
# AI_FAST_REVIEW_MODEL=qwen3-coder:30b
# OLLAMA_FAST_REVIEW_BASE_URL=http://127.0.0.1:11437
# OLLAMA_FAST_REVIEW_MODEL=qwen3-coder:30b

# Gemma 2 HAL programming error review (on-demand; scripts/run_gemma2_hal_program_eval.ps1)
# 9B fits on :11434 alongside daily lanes; 27B needs daily lanes stopped first on 16 GB VRAM.
# GEMMA2_HAL_SIZE=9b
# GEMMA2_HAL_OLLAMA_URL=http://127.0.0.1:11434
# Profile aliases: gemma2_hal_9b (hal-gemma2:9b), gemma2_hal_27b (hal-gemma2:27b)
# Dual-model sectional audit reviewer override (run_nr2_dual_model_micro_eval.ps1 reads this):
# NR2_EVAL_SECONDARY_MODEL=llama3.3:latest
# NR2_EVAL_SECONDARY_MODEL=hal-gemma2:9b

# HAL Ask routing — 14B-first daily path (fast helper, then primary, then backend review)
HAL_ENABLE_FAST_MODEL=1
HAL_FAST_MODEL_NAME=queen3:14b
HAL_FAST_MODEL_TIMEOUT_SECONDS=10
HAL_MAIN_MODEL_TIMEOUT_SECONDS=15

# Optional LiteLLM local proxy layer for OpenAI-compatible routing over Ollama.
# Start it with scripts\start_litellm_proxy.ps1 and point OpenAI-compatible tools at LITELLM_PROXY_BASE_URL.
# The proxy binds to http://127.0.0.1:4000 by default (localhost only).
# LITELLM_MASTER_KEY is required for any non-local or shared-network proxy use. Do not expose the proxy without auth.
# LITELLM_PROXY_BASE_URL=http://127.0.0.1:4000
# LITELLM_MASTER_KEY=

# HAL widget update ingestion (/api/widgets/update)
# WIDGET_API_KEY is required when APP_ENV is unset, production, staging, or any non-development value.
# For local HAL supervisor development only, set APP_ENV=development (or test) or provide WIDGET_API_KEY.
WIDGET_API_KEY=
# APP_ENV=production
# For local development only:
# APP_ENV=development
# Optional persisted snapshot for import-driven widget feed (default: app/data/cache/import_widget_feed.json)
# WIDGET_FEED_CACHE_PATH=

# Insurance narrative SoftDent export-file adapter (no E-Services/Gateway; CSV imports only)
# Place softdent_claims_export.csv, softdent_procedures_export.csv,
# softdent_patient_ledger_export.csv, softdent_claim_status_export.csv, and
# softdent_clinical_notes_export.csv in this directory.
# INSURANCE_NARRATIVE_SOFTDENT_EXPORT_DIR=app/data/imports/insurance_narratives/softdent
