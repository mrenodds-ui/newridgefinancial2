# Add your OpenAI API key here
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
QUICKBOOKS_DSN=QuickBooks Data QRemote

# Backend auth users are loaded from deployment configuration.
# Prefer password_hash entries. Plaintext password is a compatibility fallback only.
# Example roles: dashboard:read, hal:operator, hal:index:refresh, admin
APP_AUTH_USERS_JSON=[{"username":"admin","display_name":"Administrator","password_hash":"pbkdf2_sha256$100000$aa449def4e3d890e8025cba20aba4762$99df292e949045bb7a97464beab93ad8b78e8907f9bfa079936e31ff0b81ef34","roles":["dashboard:read","hal:operator","hal:index:refresh","admin"]},{"username":"hal_operator","display_name":"HAL Operator","password_hash":"pbkdf2_sha256$100000$3420c2ad6b90fddf59f83e7d65718d35$6a967acb0cf91b4a79ee85de47e5aacdd721c16ee14d16d63bf177842223ff4a","roles":["dashboard:read","hal:operator"]}]

# HAL persistence paths
HAL_SQLITE_PATH=
HAL_CHROMA_PATH=
HAL_EMBEDDING_PROVIDER=onnx-minilm

# Optional approved read-only QuickBooks summary queries for HAL.
# HAL will not run arbitrary SQL. If these are blank, HAL will try built-in
# read-only fallback templates for common QODBC summary topics.
HAL_QB_REVENUE_SQL=SELECT TOP 1 TotalIncome, ReportPeriod FROM ProfitAndLossSummary ORDER BY ReportPeriod DESC
HAL_QB_EXPENSES_SQL=SELECT TOP 1 TotalExpense, ReportPeriod FROM ProfitAndLossSummary ORDER BY ReportPeriod DESC
HAL_QB_AR_SQL=SELECT TOP 1 BalanceRemaining AS OutstandingAR, TxnDate AS ReportDate, RefNumber FROM Invoice ORDER BY TxnDate DESC

# Local LLM runtime (AMD Radeon RX 9060 XT 16GB — Vulkan-first Ollama on Windows)
# Model targets live in evals/local_model_profiles.json (Mistral Small 3.1 24B primary GPU lane; Qwen3 30B second-opinion CPU/RAM lane).
# Leave OLLAMA_NUM_GPU_OVERRIDE unset for profile GPU offload (num_gpu=999 = all layers).
# Set OLLAMA_NUM_GPU_OVERRIDE=0 only when forcing CPU-only debugging.
# OLLAMA_NUM_GPU_OVERRIDE=
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional LiteLLM local proxy layer for OpenAI-compatible routing over Ollama.
# Start it with scripts\start_litellm_proxy.ps1 and point OpenAI-compatible tools at LITELLM_PROXY_BASE_URL.
# LITELLM_PROXY_BASE_URL=http://127.0.0.1:4000
# LITELLM_MASTER_KEY=

# HAL widget update ingestion (/api/widgets/update)
# /api/widgets/update requires WIDGET_API_KEY outside explicit development/test contexts.
# For local HAL supervisor development, set APP_ENV=development or provide WIDGET_API_KEY.
WIDGET_API_KEY=
APP_ENV=development
